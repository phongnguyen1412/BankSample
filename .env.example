APP_NAME=BankImport
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug
CACHE_STORE=file

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=bank_import
DB_USERNAME=root
DB_PASSWORD=123456

FILESYSTEM_DISK=local
QUEUE_CONNECTION=rabbitmq

IMPORT_STORAGE_DISK=local
IMPORT_STORAGE_DIRECTORY=imports
CSV_IMPORT_CHUNK_SIZE=1000

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=csv-imports
RABBITMQ_EXCHANGE=topic
RABBITMQ_ROUTING_KEY=csv-imports
RABBITMQ_WORKER=default
RABBITMQ_HEARTBEAT=30
RABBITMQ_READ_WRITE_TIMEOUT=60
